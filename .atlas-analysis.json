  "keyFeatures": [
    "Finder-style file browser with breadcrumb navigation",
    "Drag-and-drop file and folder uploads with concurrent progress tracking",
    "Menu bar widget for instant file uploads and recent uploads access",
    "Multiple R2 bucket support with bucket switcher",
    "Presigned URL generation for secure file sharing",
    "Auto-update system with in-app download and install",
    "Quick Look preview integration",
    "Recursive folder operations (delete all contents)",
    "Automatic public URL copy to clipboard"
  ],
  "publicApiSurface": [
    "R2UploadService.upload(fileURL:credentials:key:contentType:onProgress:)",
    "R2UploadService.testConnection(credentials:)",
    "R2BrowseService.listObjects(credentials:prefix:)",
    "R2BrowseService.createFolder(credentials:folderKey:)",
    "R2BrowseService.deleteObject(credentials:key:)",
    "R2BrowseService.listAllKeys(credentials:prefix:)",
    "AWSV4Signer.sign(request:credentials:payloadHash:date:)",
    "AWSV4Signer.presignedURL(for:credentials:expiresIn:date:)",
    "KeychainService.save(_:forKey:)",
    "KeychainService.retrieve(forKey:)",
    "MenuBarManager.init(viewModel:)",
    "UpdateService.checkForUpdates()",
    "R2Credentials.publicURL(forKey:)",
    "R2Credentials.endpoint"
  ]
